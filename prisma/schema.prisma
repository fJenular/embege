generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model detail_pemesanans {
  id           BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  id_paket     BigInt?     @db.UnsignedBigInt
  subtotal     BigInt?
  created_at   DateTime?   @db.Timestamp(0)
  updated_at   DateTime?   @db.Timestamp(0)
  id_pemesanan BigInt?     @db.UnsignedBigInt
  pakets       pakets?     @relation(fields: [id_paket], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "detail_pemesanans_ibfk_1")
  pemesanans   pemesanans? @relation(fields: [id_pemesanan], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_detail_pemesanan")

  @@index([id_pemesanan], map: "fk_detail_pemesanan")
  @@index([id_paket], map: "id_paket")
}

model jenis_pembayarans {
  id                BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  metode_pembayaran String?      @db.VarChar(30)
  created_at        DateTime?    @db.Timestamp(0)
  updated_at        DateTime?    @db.Timestamp(0)
  pemesanans        pemesanans[]
}

model pakets {
  id                BigInt              @id @default(autoincrement()) @db.UnsignedBigInt
  nama_paket        String?             @db.VarChar(50)
  jenis             pakets_jenis?
  kategori          pakets_kategori?
  jumlah_pax        Int?
  harga_paket       Int?
  deskripsi         String?             @db.Text
  foto1             String?             @db.VarChar(255)
  foto2             String?             @db.VarChar(255)
  foto3             String?             @db.VarChar(255)
  created_at        DateTime?           @db.Timestamp(0)
  updated_at        DateTime?           @db.Timestamp(0)
  detail_pemesanans detail_pemesanans[]
}

model pelanggans {
  id             BigInt       @id @default(autoincrement()) @db.UnsignedBigInt
  nama_pelanggan String?      @db.VarChar(100)
  email          String?      @db.VarChar(255)
  password       String?      @db.VarChar(255)
  tgl_lahir      DateTime?    @db.Date
  telepon        String?      @db.VarChar(15)
  alamat1        String?      @db.VarChar(255)
  alamat2        String?      @db.VarChar(255)
  alamat3        String?      @db.VarChar(255)
  kartu_id       String?      @db.VarChar(255)
  foto           String?      @db.VarChar(255)
  created_at     DateTime?    @db.Timestamp(0)
  updated_at     DateTime?    @db.Timestamp(0)
  pemesanans     pemesanans[]
}

model pemesanans {
  id                BigInt                   @id @default(autoincrement()) @db.UnsignedBigInt
  id_pelanggan      BigInt?                  @db.UnsignedBigInt
  id_jenis_bayar    BigInt?                  @db.UnsignedBigInt
  no_resi           String?                  @db.VarChar(30)
  tgl_pesan         DateTime?                @db.DateTime(0)
  status_pesan      pemesanans_status_pesan?
  total_bayar       BigInt?
  bukti_bayar       String?                  @db.VarChar(255)
  created_at        DateTime?                @db.Timestamp(0)
  updated_at        DateTime?                @db.Timestamp(0)
  detail_pemesanans detail_pemesanans[]
  pelanggans        pelanggans?              @relation(fields: [id_pelanggan], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "pemesanans_ibfk_1")
  jenis_pembayarans jenis_pembayarans?       @relation(fields: [id_jenis_bayar], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "pemesanans_ibfk_2")
  pengirimans       pengirimans[]

  @@index([id_jenis_bayar], map: "id_jenis_bayar")
  @@index([id_pelanggan], map: "id_pelanggan")
}

model pengirimans {
  id           BigInt                    @id @default(autoincrement()) @db.UnsignedBigInt
  tgl_kirim    DateTime?                 @db.DateTime(0)
  tgl_tiba     DateTime?                 @db.DateTime(0)
  status_kirim pengirimans_status_kirim?
  bukti_foto   String?                   @db.VarChar(255)
  id_pesan     BigInt?                   @db.UnsignedBigInt
  id_user      BigInt?                   @db.UnsignedBigInt
  created_at   DateTime?                 @db.Timestamp(0)
  updated_at   DateTime?                 @db.Timestamp(0)
  pemesanans   pemesanans?               @relation(fields: [id_pesan], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_pengiriman_pemesanan")
  users        users?                    @relation(fields: [id_user], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_pengiriman_user")

  @@index([id_pesan], map: "fk_pengiriman_pemesanan")
  @@index([id_user], map: "fk_pengiriman_user")
}

model users {
  id          BigInt        @id @default(autoincrement()) @db.UnsignedBigInt
  name        String?       @db.VarChar(30)
  email       String?       @db.VarChar(255)
  password    String?       @db.VarChar(255)
  level       users_level?
  created_at  DateTime?     @db.Timestamp(0)
  updated_at  DateTime?     @db.Timestamp(0)
  pengirimans pengirimans[]
}

enum pakets_jenis {
  Prasmanan
  Box
}

enum pakets_kategori {
  Pernikahan
  Selamatan
  Ulang_Tahun @map("Ulang Tahun")
  Studi_Tour  @map("Studi Tour")
  Rapat
}

enum pengirimans_status_kirim {
  Sedang_Dikirim @map("Sedang Dikirim")
  Tiba_Ditujuan  @map("Tiba Ditujuan")
}

enum users_level {
  admin
  owner
  kurir
}

enum pemesanans_status_pesan {
  Menunggu_Konfirmasi @map("Menunggu Konfirmasi")
  Sedang_Diproses     @map("Sedang Diproses")
  Menunggu_Kurir      @map("Menunggu Kurir")
  Selesai             @map("Selesai")
}
